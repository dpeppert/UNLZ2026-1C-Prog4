@model Web.Data.Tables.Evento

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit</h1>

<h4>EventoVM</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Editar">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="IdEvento" class="control-label"></label>
                <input asp-for="IdEvento" class="form-control" />
                <span asp-validation-for="IdEvento" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NombreEvento" class="control-label"></label>
                <input asp-for="NombreEvento" class="form-control" />
                <span asp-validation-for="NombreEvento" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FechaEvento" class="control-label"></label>
                <input asp-for="FechaEvento" class="form-control" />
                <span asp-validation-for="FechaEvento" class="text-danger"></span>
            </div>

            <div class="form-group">
                @Html.DropDownListFor(
                Model => Model.IdProvincia,
                                (SelectList)ViewBag.SelectProvincias,
                                "Seleccione una provincia..."),
<!--
                <select asp-for="IdProvincia" asp-items="ViewBag.Provincias">
                    <option>Seleccione una opción</option>

                                </select>-->
            </div>

            <div class="form-group">
                @Html.RadioButtonFor(x=> x.IdUbicacion, "1") Movistar Argenta 
                @Html.RadioButtonFor(x => x.IdUbicacion, "2") El Monumental
                @Html.RadioButtonFor(x => x.IdUbicacion, "3") El Cilindro

            </div>

            <div class="form-group">
                <input type="checkbox" asp-for="Activo" value="@Model.Activo" />
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
